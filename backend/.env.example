# Server
PORT=5000
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# AI Engine
ANTHROPIC_API_KEY=your-anthropic-api-key

# Auth
JWT_SECRET=hialice-secret-change-in-prod

# Speech (optional)
OPENAI_API_KEY=your-openai-key
ELEVENLABS_API_KEY=your-elevenlabs-key

# Error Tracking (optional)
# Create a project at https://sentry.io and paste the Node DSN here.
# Leave blank to disable Sentry entirely (safe for local development).
SENTRY_DSN=
# Fraction of requests to trace (0.0 – 1.0). Defaults to 0.1 in sentry.js.
SENTRY_TRACES_SAMPLE_RATE=0.1
