# ============================================
# HiAlice Environment Configuration
# Copy this file to .env.local and fill in actual values
# ============================================

# ============================================
# Backend Server
# ============================================
NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001

# ============================================
# Frontend (Public - exposed to browser)
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ============================================
# Supabase Configuration
# Get these from your Supabase project settings
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# ============================================
# PostgreSQL Database (for local development)
# ============================================
DB_USER=hialice
DB_PASSWORD=hialice-dev-password
DB_NAME=hialice_db
DB_HOST=postgres
DB_PORT=5432

# ============================================
# AI Engine - Anthropic Claude
# Get API key from https://console.anthropic.com/
# ============================================
ANTHROPIC_API_KEY=your-anthropic-api-key

# ============================================
# Speech Recognition & Synthesis (Optional)
# For STT: OpenAI Whisper
# Get key from https://platform.openai.com/
# ============================================
OPENAI_API_KEY=your-openai-api-key

# ============================================
# Text-to-Speech (Optional)
# For TTS: ElevenLabs
# Get key from https://elevenlabs.io/
# ============================================
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# ============================================
# Authentication
# Generate a secure random string for production
# Example: openssl rand -base64 32
# ============================================
JWT_SECRET=hialice-dev-secret-change-in-prod
JWT_EXPIRY=7d

# ============================================
# Email Configuration (Optional - for notifications)
# ============================================
SMTP_HOST=your-smtp-host
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-email-password
EMAIL_FROM=noreply@hialice.app

# ============================================
# Logging & Monitoring (Optional)
# ============================================
LOG_LEVEL=info
# Backend (Node) DSN — get from Sentry project > Settings > Client Keys
SENTRY_DSN=
# Browser DSN — exposed to the client bundle (NEXT_PUBLIC_ prefix required)
NEXT_PUBLIC_SENTRY_DSN=

# ============================================
# Feature Flags
# ============================================
ENABLE_SPEECH_RECOGNITION=true
ENABLE_TTS=true
ENABLE_IMAGE_GENERATION=false
MAINTENANCE_MODE=false
